{
  "name": "ts-zxcvbn",
  "version": "5.1.1",
  "description": "realistic password strength estimation",
  "author": "Joni Mertoniemi",
  "license": "MIT",
  "main": "dist/main.js",
  "module": "dist/main.mjs",
  "types": "dist/main.d.ts",
  "exports": {
    ".": {
      "types": "./dist/main.d.ts",
      "import": "./dist/main.mjs",
      "require": "./dist/main.js"
    }
  },
  "repository": "jonime/ts-zxcvbn",
  "jest": {
    "moduleNameMapper": {
      "^\\.(.*)\\.js$": ".$1"
    }
  },
  "scripts": {
    "test": "jest && npm run test:packaging",
    "test:packaging": "npm run build && cd tests/packaging && npm install && npm test",
    "build": "tsup",
    "prepare": "npm run build",
    "build-lists": "npm run build-frequency-lists && npm run build-keyboard-adjacency-graphs",
    "build-frequency-lists": "python data-scripts/build_frequency_lists.py data src/frequency_lists.ts",
    "build-keyboard-adjacency-graphs": "python data-scripts/build_keyboard_adjacency_graphs.py src/adjacency_graphs.ts",
    "release": "semantic-release"
  },
  "devDependencies": {
    "@babel/core": "^7.9.0",
    "@babel/preset-env": "^7.9.5",
    "@babel/preset-typescript": "^7.9.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^10.1.4",
    "@semantic-release/npm": "^13.0.0",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@types/jest": "^25.2.1",
    "babel-jest": "^30.3.0",
    "conventional-changelog-conventionalcommits": "^9.0.0",
    "jest": "^30.3.0",
    "rimraf": "^3.0.2",
    "semantic-release": "^25.0.3",
    "tsup": "8.5.1",
    "typescript": "5.9.3"
  },
  "overrides": {
    "@semantic-release/npm": "^13.0.0"
  },
  "keywords": [
    "password",
    "passphrase",
    "security",
    "authentication",
    "strength",
    "meter",
    "quality",
    "estimation",
    "pattern",
    "cracking",
    "scoring",
    "entropy",
    "bruteforce"
  ]
}
