{
  "name": "ts-zxcvbn",
  "version": "5.1.1",
  "description": "realistic password strength estimation",
  "author": "Joni Mertoniemi",
  "license": "MIT",
  "main": "dist/main.js",
  "module": "dist/main.mjs",
  "types": "dist/main.d.ts",
  "exports": {
    ".": {
      "types": "./dist/main.d.ts",
      "import": "./dist/main.mjs",
      "require": "./dist/main.js"
    }
  },
  "repository": "jonime/ts-zxcvbn",
  "jest": {
    "moduleNameMapper": {
      "^\\.(.*)\\.js$": ".$1"
    }
  },
  "scripts": {
    "test": "jest && npm run test:packaging",
    "test:packaging": "npm run build && cd tests/packaging && npm install && npm test",
    "build": "tsup",
    "prepare": "npm run build",
    "build-lists": "npm run build-frequency-lists && npm run build-keyboard-adjacency-graphs",
    "build-frequency-lists": "tsx data-scripts/build_frequency_lists.ts data src/frequency_lists.ts",
    "build-keyboard-adjacency-graphs": "tsx data-scripts/build_keyboard_adjacency_graphs.ts src/adjacency_graphs.ts",
    "release": "semantic-release"
  },
  "devDependencies": {
    "@babel/core": "7.29.0",
    "@babel/preset-env": "7.29.0",
    "@babel/preset-typescript": "7.28.5",
    "@semantic-release/changelog": "6.0.3",
    "@semantic-release/commit-analyzer": "13.0.1",
    "@semantic-release/git": "10.0.1",
    "@semantic-release/github": "12.0.6",
    "@semantic-release/npm": "13.1.5",
    "@semantic-release/release-notes-generator": "14.1.0",
    "@types/jest": "30.0.0",
    "babel-jest": "30.3.0",
    "conventional-changelog-conventionalcommits": "9.3.0",
    "jest": "30.3.0",
    "prettier": "3.8.1",
    "rimraf": "6.1.3",
    "semantic-release": "25.0.3",
    "tsup": "8.5.1",
    "tsx": "4.21.0",
    "typescript": "5.9.3"
  },
  "keywords": [
    "password",
    "passphrase",
    "security",
    "authentication",
    "strength",
    "meter",
    "quality",
    "estimation",
    "pattern",
    "cracking",
    "scoring",
    "entropy",
    "bruteforce"
  ]
}
