{
  "name": "ts-zxcvbn",
  "version": "7.0.1",
  "description": "realistic password strength estimation",
  "author": "Joni Mertoniemi",
  "license": "MIT",
  "homepage": "https://jonime.github.io/ts-zxcvbn/",
  "main": "dist/main.js",
  "module": "dist/main.mjs",
  "types": "dist/main.d.ts",
  "exports": {
    ".": {
      "types": "./dist/main.d.ts",
      "import": "./dist/main.mjs",
      "require": "./dist/main.js"
    },
    "./names/finnish": {
      "types": "./dist/names/finnish.d.ts",
      "import": "./dist/names/finnish.mjs",
      "require": "./dist/names/finnish.js"
    },
    "./names/english": {
      "types": "./dist/names/english.d.ts",
      "import": "./dist/names/english.mjs",
      "require": "./dist/names/english.js"
    },
    "./frequencies/passwords": {
      "types": "./dist/frequencies/passwords.d.ts",
      "import": "./dist/frequencies/passwords.mjs",
      "require": "./dist/frequencies/passwords.js"
    },
    "./frequencies/passwords-lite": {
      "types": "./dist/frequencies/passwords-lite.d.ts",
      "import": "./dist/frequencies/passwords-lite.mjs",
      "require": "./dist/frequencies/passwords-lite.js"
    }
  },
  "repository": "jonime/ts-zxcvbn",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:packaging": "npm run build && node tests/packaging/check-bundle-size.mjs && cd tests/packaging && npm install && npm test",
    "build": "npm run build-name-lists && npm run build-frequency-lists && tsup",
    "build-name-lists": "tsx data-scripts/build_name_lists.ts",
    "prepare": "npm run build",
    "build-lists": "npm run build-frequency-lists && npm run build-keyboard-adjacency-graphs",
    "build-frequency-lists": "tsx data-scripts/build_frequency_lists.ts data src/frequencies",
    "build-keyboard-adjacency-graphs": "tsx data-scripts/build_keyboard_adjacency_graphs.ts src/adjacency_graphs.ts",
    "release": "semantic-release",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "benchmark": "cd benchmark && npm install && npm run benchmark",
    "benchmark:update-docs": "cd benchmark && npm install && node run.mjs --out=../docs/benchmark-results.json"
  },
  "devDependencies": {
    "@semantic-release/changelog": "6.0.3",
    "@semantic-release/commit-analyzer": "13.0.1",
    "@semantic-release/git": "10.0.1",
    "@semantic-release/github": "12.0.6",
    "@semantic-release/npm": "13.1.5",
    "@semantic-release/release-notes-generator": "14.1.0",
    "conventional-changelog-conventionalcommits": "9.3.0",
    "vitest": "4.1.1",
    "prettier": "3.8.1",
    "rimraf": "6.1.3",
    "semantic-release": "25.0.3",
    "tsup": "8.5.1",
    "tsx": "4.21.0",
    "typescript": "6.0.2",
    "vitepress": "1.6.4"
  },
  "overrides": {
    "esbuild": "0.27.3"
  },
  "keywords": [
    "password",
    "passphrase",
    "security",
    "authentication",
    "strength",
    "meter",
    "quality",
    "estimation",
    "pattern",
    "cracking",
    "scoring",
    "entropy",
    "bruteforce"
  ]
}
